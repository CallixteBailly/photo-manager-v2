<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PhotoManager.UI.Avalonia.Windows.AboutWindow"
        Title="About PhotoManager"
        Width="400"
        Height="300"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <StackPanel Spacing="10">
            <TextBlock Text="PhotoManager" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="Version 1.8.0" />
            <TextBlock Text="Cross-Platform Photo Management Application" />
            <TextBlock Text="" />
            <TextBlock Text="© 2026 PhotoManager Contributors" />
        </StackPanel>
    </Grid>
</Window>
